---
import BaseLayout from "../layouts/BaseLayout.astro";

const areas = [
  "experimental design for learning and cognitive outcomes",
  "evaluation of AI explanations, reasoning traces, and human-AI interaction",
  "behavioral studies of trust, overreliance, transfer, and calibration",
  "child and developmental research methods",
  "measurement strategies for populations where self-report is limited",
  "translating cognitive science into rigorous, testable evaluation frameworks",
];
---

<BaseLayout title="Consulting and Collaboration | Lauren Aulet">
  <header class="site-header">
    <a class="brand" href="/">Lauren Aulet</a>
    <nav aria-label="Primary navigation">
      <a href="/#about">About</a>
      <a href="/#research">Research</a>
      <a href="/#publications">Publications</a>
      <a href="/consulting/">Consulting</a>
      <a href="/elsewhere/">Elsewhere</a>
      <a href="/files/Aulet_CV.pdf">CV</a>
    </nav>
  </header>

  <main>
    <section class="page-hero">
      <p class="eyebrow">Collaboration</p>
      <h1>Measuring cognition, learning, and reasoning in human and artificial systems.</h1>
      <p>
        I collaborate with researchers, organizations, and AI teams interested in turning cognitive
        science questions into careful, testable evaluation work.
      </p>
    </section>

    <section class="two-column">
      <div>
        <p class="section-kicker">Approach</p>
        <h2>Define the construct. Build the task. Test the alternative explanations.</h2>
      </div>
      <div class="prose">
        <p>
          My approach is grounded in cognitive science: define the construct clearly, design tasks
          that can distinguish competing explanations, and evaluate outcomes behaviorally rather than
          relying only on self-report or engagement metrics.
        </p>
        <p>
          I am especially interested in settings where the important cognitive process is not directly
          observable: young children, learners, users interacting with AI systems, or models that
          produce fluent explanations without transparent access to the computations behind them.
        </p>
      </div>
    </section>

    <section class="list-section">
      <p class="section-kicker">Areas</p>
      <div class="item-grid">
        {areas.map((area) => (
          <article>
            <span></span>
            <p>{area}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="contact-band">
      <p>Interested in collaborating?</p>
      <a href="mailto:laulet@umass.edu">laulet@umass.edu</a>
    </section>
  </main>
</BaseLayout>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) {
    margin: 0;
    color: #191919;
    background: #fafafa;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  :global(a) { color: inherit; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 14px clamp(18px, 4vw, 52px);
    background: rgba(250, 250, 250, 0.96);
    border-bottom: 1px solid #d8d8d8;
    backdrop-filter: blur(8px);
  }
  .brand {
    font-weight: 800;
    text-decoration: none;
  }
  .brand::after {
    content: " / consulting";
    color: #777;
    font-weight: 500;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    font-size: 0.92rem;
  }
  nav a { text-decoration: none; }

  .page-hero {
    min-height: 430px;
    padding: clamp(54px, 9vw, 112px) clamp(18px, 4vw, 52px);
    background:
      linear-gradient(#e7e7e7 1px, transparent 1px),
      linear-gradient(90deg, #e7e7e7 1px, transparent 1px),
      #fafafa;
    background-size: 44px 44px;
    border-bottom: 1px solid #d8d8d8;
  }
  .page-hero::before {
    content: "";
    display: block;
    width: 44px;
    height: 6px;
    margin-bottom: 18px;
    background: repeating-linear-gradient(90deg, #191919 0 6px, transparent 6px 11px);
  }
  .eyebrow,
  .section-kicker {
    margin: 0 0 14px;
    color: #555;
    font-size: 0.76rem;
    font-weight: 750;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  h1,
  h2,
  p { margin-top: 0; }
  h1 {
    max-width: 980px;
    margin-bottom: 22px;
    font-size: clamp(2.8rem, 5.7vw, 5.4rem);
    line-height: 0.94;
    font-weight: 850;
  }
  h2 {
    max-width: 640px;
    font-size: clamp(1.85rem, 3.6vw, 3.4rem);
    line-height: 1.04;
    font-weight: 820;
  }
  .page-hero p,
  .prose {
    max-width: 760px;
    font-size: 1.04rem;
    line-height: 1.7;
  }
  .two-column {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.75fr);
    gap: clamp(32px, 6vw, 86px);
    padding: clamp(56px, 8vw, 104px) clamp(18px, 4vw, 52px);
    border-bottom: 1px solid #d8d8d8;
  }
  .list-section {
    padding: clamp(56px, 8vw, 104px) clamp(18px, 4vw, 52px);
    border-bottom: 1px solid #d8d8d8;
  }
  .item-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid #d8d8d8;
  }
  .item-grid article {
    min-height: 150px;
    padding: 22px 28px 22px 0;
    border-bottom: 1px solid #d8d8d8;
  }
  .item-grid span {
    display: block;
    width: 28px;
    height: 2px;
    margin-bottom: 24px;
    background: #191919;
  }
  .item-grid article:nth-child(3n + 2) span { background: #666; }
  .item-grid article:nth-child(3n) span { background: #aaa; }
  .item-grid p {
    max-width: 310px;
    line-height: 1.55;
    font-weight: 700;
  }
  .contact-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 34px clamp(18px, 4vw, 52px);
    color: #fff;
    background: #191919;
  }
  .contact-band p { margin: 0; font-weight: 800; }
  .contact-band a { font-weight: 800; text-decoration: none; }

  @media (max-width: 860px) {
    .site-header,
    .contact-band {
      align-items: flex-start;
      flex-direction: column;
    }
    .two-column,
    .item-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .brand::after { content: ""; }
    h1 { font-size: 3.3rem; }
  }
</style>
