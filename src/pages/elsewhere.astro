---
import BaseLayout from "../layouts/BaseLayout.astro";

const items = [
  {
    label: "Published poem",
    title: "Atlanta Review",
    text: "Poetry, 2021.",
    href: "http://atlantareview.com/wp-content/uploads/2024/04/AR-28.1-Poetry-2021.pdf",
  },
  {
    label: "Currently listening to",
    title: "Dots and Loops",
    text: "Stereolab.",
    href: "https://stereolab.co.uk/",
  },
  {
    label: "Currently drinking",
    title: "Allagash White and Spanish reds",
    text: "",
    href: "https://www.allagash.com/beer/white/",
  },
  {
    label: "Currently reading",
    title: "Borges and the history of cybernetics",
    text: "",
    href: "https://en.wikipedia.org/wiki/Jorge_Luis_Borges",
  },
  {
    label: "Currently obsessed with",
    title: "ARC-AGI",
    text: "",
    href: "https://arcprize.org/",
  },
  {
    label: "Currently talking about",
    title: "Women scientists and academic research",
    text: "The 19th.",
    href: "https://19thnews.org/2026/02/epstein-files-academic-research-women-scientists/",
  },
];
---

<BaseLayout title="Elsewhere | Lauren Aulet">
  <header class="site-header">
    <a class="brand" href="/">Lauren Aulet</a>
    <nav aria-label="Primary navigation">
      <a href="/#about">About</a>
      <a href="/#research">Research</a>
      <a href="/#publications">Publications</a>
      <a href="/elsewhere/">Elsewhere</a>
      <a href="/files/Aulet_CV.pdf">CV</a>
    </nav>
  </header>

  <main>
    <section class="page-hero">
      <p class="eyebrow">Elsewhere</p>
      <h1>Some things I have made, loved, joined, or keep thinking about.</h1>
      <p>
        A less formal shelf for poetry, talks, side projects, recommendations, and whatever else does
        not quite fit on an academic CV.
      </p>
    </section>

    <section class="item-list">
      {items.map((item) => (
        <a class="item" href={item.href}>
          <p>{item.label}</p>
          <h2>{item.title}</h2>
          {item.text && <span>{item.text}</span>}
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) {
    margin: 0;
    color: #191919;
    background: #fafafa;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  :global(a) { color: inherit; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 14px clamp(18px, 4vw, 52px);
    background: rgba(250, 250, 250, 0.96);
    border-bottom: 1px solid #d8d8d8;
    backdrop-filter: blur(8px);
  }
  .brand {
    font-weight: 800;
    text-decoration: none;
  }
  .brand::after {
    content: " / elsewhere";
    color: #777;
    font-weight: 500;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    font-size: 0.92rem;
  }
  nav a { text-decoration: none; }

  .page-hero {
    min-height: 430px;
    padding: clamp(54px, 9vw, 112px) clamp(18px, 4vw, 52px);
    background:
      linear-gradient(#e7e7e7 1px, transparent 1px),
      linear-gradient(90deg, #e7e7e7 1px, transparent 1px),
      #fafafa;
    background-size: 44px 44px;
    border-bottom: 1px solid #d8d8d8;
  }
  .page-hero::before {
    content: "";
    display: block;
    width: 44px;
    height: 6px;
    margin-bottom: 18px;
    background: repeating-linear-gradient(90deg, #191919 0 6px, transparent 6px 11px);
  }
  .eyebrow {
    margin: 0 0 14px;
    color: #555;
    font-size: 0.76rem;
    font-weight: 750;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  h1,
  h2,
  p { margin-top: 0; }
  h1 {
    max-width: 1000px;
    margin-bottom: 22px;
    font-size: clamp(2.8rem, 5.7vw, 5.4rem);
    line-height: 0.94;
    font-weight: 850;
  }
  .page-hero p:last-child {
    max-width: 720px;
    font-size: 1.04rem;
    line-height: 1.7;
  }
  .item-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-bottom: 1px solid #d8d8d8;
  }
  .item {
    min-height: 310px;
    padding: clamp(28px, 5vw, 52px);
    border-right: 1px solid #d8d8d8;
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease;
  }
  .item:nth-child(3n) { border-right: 0; }
  .item:nth-child(n + 4) { border-top: 1px solid #d8d8d8; }
  .item:hover {
    color: #fff;
    background: #191919;
  }
  .item p {
    margin-bottom: 26px;
    color: #666;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }
  .item:hover p { color: #fff; }
  .item h2 {
    margin-bottom: 18px;
    font-size: clamp(1.9rem, 3.4vw, 3.5rem);
    line-height: 0.98;
    font-weight: 850;
  }
  .item span {
    display: block;
    max-width: 320px;
    line-height: 1.62;
  }

  @media (max-width: 860px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }
    .item-list {
      grid-template-columns: 1fr;
    }
    .item {
      min-height: auto;
      border-right: 0;
      border-bottom: 1px solid #d8d8d8;
    }
  }
  @media (max-width: 560px) {
    .brand::after { content: ""; }
    h1 { font-size: 3.3rem; }
  }
</style>
